DOM_EXTRACT_SCRIPT = r"""
(() => {
  function cleanText(value) {
    return (value || "").replace(/\s+/g, " ").trim();
  }

  // Text-node whitespace carries the separation between adjacent inline
  // elements.  Do not trim it here: for `one <a>two</a> three`, trimming the
  // two text nodes would serialize the content as `one<a>two</a>three`.
  function normalizedTextNode(value) {
    return (value || "").replace(/\s+/g, " ");
  }

  function absoluteUrl(value) {
    if (!value) return "";
    try {
      const url = new URL(value, window.location.href);
      if (url.protocol === "http:" || url.protocol === "https:") return url.href;
    } catch (e) {
    }
    return "";
  }

  function visibleElement(el) {
    if (!el || el.nodeType !== Node.ELEMENT_NODE) return false;
    const tag = el.tagName;
    if (tag === "HTML" || tag === "HEAD" || tag === "BODY" ||
        tag === "TITLE" || tag === "META" || tag === "LINK") return true;
    if (el.hidden || el.getAttribute("aria-hidden") === "true") return false;
    const style = window.getComputedStyle(el);
    if (!style || style.display === "none" || style.visibility === "hidden" ||
        Number(style.opacity) === 0) return false;
    const text = cleanText(
      typeof el.innerText === "string" ? el.innerText : (el.textContent || "")
    );
    const rect = el.getBoundingClientRect();
    return text.length > 0 || rect.width > 0 || rect.height > 0;
  }

  function bestUrl(el) {
    const attrs = [
      "href", "data-href", "data-url", "data-link", "data-target-url",
      "data-destination", "to", "formaction"
    ];
    for (const attr of attrs) {
      const url = absoluteUrl(el.getAttribute(attr));
      if (url) return url;
    }
    const onclick = el.getAttribute("onclick") || "";
    const match = onclick.match(/(?:location(?:\.href)?|window\.open)\s*\(?\s*['"]([^'"]+)['"]/i);
    if (match) return absoluteUrl(match[1]);
    return "";
  }

  function elementLabel(el) {
    return cleanText(
      el.getAttribute("aria-label") ||
      el.innerText ||
      el.textContent ||
      el.getAttribute("title") ||
      el.value ||
      ""
    );
  }

  function insertSyntheticLink(el, label, url) {
    if (!label || !url || el.closest("a")) return;
    const a = document.createElement("a");
    a.href = url;
    a.textContent = label;
    a.setAttribute("data-simplebrowse-synthetic", "1");
    el.insertAdjacentElement("afterend", a);
  }

  for (const el of Array.from(document.querySelectorAll(
       "button, [role='link'], [onclick], [data-href], [data-url], [data-target-url], [data-destination]"))) {
    if (!visibleElement(el)) continue;
    if (el.closest("form")) continue;
    const label = elementLabel(el);
    const url = bestUrl(el);
    if (/^open form target$/i.test(label)) continue;
    if (label && url) insertSyntheticLink(el, label, url);
  }

  function associatedLabel(el) {
    if (!el) return "";
    if (el.id) {
      const escaped = window.CSS && CSS.escape ? CSS.escape(el.id) : el.id.replace(/"/g, '\\"');
      try {
        const explicit = document.querySelector(`label[for="${escaped}"]`);
        const text = cleanText(explicit && (explicit.innerText || explicit.textContent));
        if (text) return text;
      } catch (e) {
      }
    }
    const wrapping = el.closest("label");
    const wrapText = cleanText(wrapping && (wrapping.innerText || wrapping.textContent));
    if (wrapText) return wrapText;
    return "";
  }

  for (const el of Array.from(document.querySelectorAll("input, textarea, select, button"))) {
    if (!visibleElement(el)) continue;
    const label = cleanText(
      el.getAttribute("aria-label") ||
      associatedLabel(el) ||
      el.getAttribute("placeholder") ||
      el.getAttribute("title") ||
      el.getAttribute("value") ||
      el.getAttribute("name") ||
      el.id ||
      ""
    );
    if (label) el.setAttribute("data-simplebrowse-label", label);
  }

  function escapeHtml(value) {
    return (value || "").replace(/[&<>]/g, (ch) => ({
      "&": "&amp;",
      "<": "&lt;",
      ">": "&gt;"
    }[ch]));
  }

  function escapeAttr(value) {
    return escapeHtml(value).replace(/"/g, "&quot;");
  }

  function elementText(el) {
    if (!el) return "";
    return cleanText(
      typeof el.innerText === "string" ? el.innerText : (el.textContent || "")
    );
  }

  function visibleTextChars(el) {
    return elementText(el).replace(/[^0-9A-Za-z]+/g, "").length;
  }

  function attrHaystack(el) {
    return cleanText([
      el.getAttribute("role"),
      el.getAttribute("class"),
      el.getAttribute("id"),
      el.getAttribute("aria-label")
    ].filter(Boolean).join(" ")).toLowerCase();
  }

  function wordish(haystack, word) {
    return new RegExp(`(^|[^a-z0-9])${word}([^a-z0-9]|$)`, "i").test(haystack || "");
  }

  function elementLooksLikeChrome(el, root) {
    if (!el || el === root) return false;
    if (el.querySelector &&
        el.querySelector("main,[role='main'],article,[role='article']"))
      return false;
    const tag = el.tagName;
    if (tag === "NAV" || tag === "FOOTER" || tag === "ASIDE" ||
        tag === "MENU" || tag === "DIALOG") return true;
    if (tag === "HEADER" &&
        el.querySelectorAll("a[href], button, input, select").length >= 3 &&
        elementText(el).length < 700) return true;

    const haystack = attrHaystack(el);
    const terms = [
      "advert", "advertisement", "affiliate", "breadcrumb", "cookie",
      "drawer", "footer", "masthead", "modal", "newsletter",
      "overlay", "pagination", "popup", "promo", "share", "sharing",
      "sidebar", "signin", "signup", "social", "sponsor", "sponsored",
      "subscribe", "toolbar", "toc", "mw-editsection"
    ];
    return terms.some((term) =>
      wordish(haystack, term) || (term.length >= 6 && haystack.includes(term))
    );
  }

  function elementHardSkippable(el) {
    if (!el || el.nodeType !== Node.ELEMENT_NODE) return true;
    const tag = el.tagName;
    return tag === "HTML" || tag === "HEAD" || tag === "TITLE" ||
      tag === "META" || tag === "LINK" || tag === "SCRIPT" ||
      tag === "STYLE" || tag === "NOSCRIPT" || tag === "TEMPLATE" ||
      tag === "SVG" || tag === "IFRAME" || tag === "CANVAS" ||
      tag === "OBJECT" || tag === "EMBED" || tag === "SOURCE" ||
      tag === "TRACK" || tag === "PORTAL" || el.hidden ||
      el.getAttribute("aria-hidden") === "true" ||
      el.getAttribute("type") === "application/json";
  }

  function candidateScore(el) {
    if (!el || elementHardSkippable(el) || !visibleElement(el)) return -1000000000;

    const textChars = visibleTextChars(el);
    const links = Array.from(el.querySelectorAll("a[href]"));
    const controls = el.querySelectorAll("input, textarea, select, button").length;
    if (textChars < 80 && links.length < 3 && controls < 1) return -1000000000;

    const tag = el.tagName.toLowerCase();
    const role = (el.getAttribute("role") || "").toLowerCase();
    const haystack = attrHaystack(el);
    const linkChars = links.reduce((sum, a) => sum + cleanText(a.innerText || a.textContent || "").length, 0);
    const headings = el.querySelectorAll("h1,h2,h3,h4,h5,h6").length;
    const repeatedItems = el.querySelectorAll("article,[role='article'],li,search-result,shreddit-post").length;
    let score = textChars + headings * 280 + repeatedItems * 520 + controls * 240;

    if (tag === "main" || tag === "article" || role === "main" || role === "article")
      score += 5000;
    if (wordish(haystack, "main") || wordish(haystack, "content") ||
        wordish(haystack, "article") || wordish(haystack, "body") ||
        wordish(haystack, "feed") || wordish(haystack, "results"))
      score += 1800;
    if (elementLooksLikeChrome(el, null))
      score -= 6000;
    if (links.length > 0 && repeatedItems < 3) {
      const linkPct = Math.floor((linkChars * 100) / Math.max(elementText(el).length, 1));
      if (linkPct > 65) score -= (linkPct - 65) * 80;
    }
    return score;
  }

  function bestContentRoot() {
    const body = document.body || document.documentElement;
    const preferredSelectors = [
      "#mw-content-text .mw-parser-output",
      "#mw-content-text",
      ".mw-parser-output",
      "article",
      "main",
      "[role='main']",
      "[role='article']"
    ];
    let preferred = null;
    let preferredScore = -1000000000;

    for (const selector of preferredSelectors) {
      for (const el of Array.from(document.querySelectorAll(selector))) {
        const score = candidateScore(el);
        if (score > preferredScore) {
          preferred = el;
          preferredScore = score;
        }
      }
    }
    if (preferred && preferredScore > -1000000000)
      return preferred;

    let best = body;
    let bestScore = candidateScore(body);
    for (const el of Array.from(document.querySelectorAll("*"))) {
      const score = candidateScore(el);
      if (score > bestScore) {
        best = el;
        bestScore = score;
      }
    }
    return best || body || document.documentElement;
  }

  function emitTextNode(node, out) {
    const text = normalizedTextNode(node.nodeValue || "");
    if (text) out.push(escapeHtml(text));
  }

  function emitAnchor(el, out) {
    const url = absoluteUrl(el.getAttribute("href") || "");
    const label = elementLabel(el);
    if (!url || !label) return;
    out.push(`<a href="${escapeAttr(url)}">${escapeHtml(label)}</a>`);
  }

  function emitImage(el, out) {
    const label = cleanText(el.getAttribute("alt") || el.getAttribute("title") || "");
    if (label) out.push(`<p>[Image: ${escapeHtml(label)}]</p>`);
  }

  function emitControl(el, out) {
    const tag = el.tagName.toLowerCase();
    const type = ((el.getAttribute("type") || el.type || "") + "").toLowerCase();
    const label = cleanText(
      el.getAttribute("data-simplebrowse-label") ||
      elementLabel(el) ||
      el.getAttribute("placeholder") ||
      el.getAttribute("aria-label") ||
      el.getAttribute("name") ||
      el.id ||
      "Search"
    );
    const name = el.getAttribute("name") || "";
    const value = el.value || el.getAttribute("value") || "";
    const common = ` name="${escapeAttr(name)}" value="${escapeAttr(value)}" data-simplebrowse-label="${escapeAttr(label)}"`;

    if (tag === "input") {
      out.push(`<input type="${escapeAttr(type || "text")}"${common}${el.checked ? " checked" : ""}>`);
    } else if (tag === "textarea") {
      out.push(`<textarea name="${escapeAttr(name)}" data-simplebrowse-label="${escapeAttr(label)}">${escapeHtml(value)}</textarea>`);
    } else if (tag === "select") {
      out.push(`<select name="${escapeAttr(name)}" data-simplebrowse-label="${escapeAttr(label)}">`);
      for (const option of Array.from(el.options || [])) {
        out.push(`<option value="${escapeAttr(option.value || "")}"${option.selected ? " selected" : ""}>${escapeHtml(cleanText(option.text || option.label || option.value || ""))}</option>`);
      }
      out.push("</select>");
    } else if (tag === "button") {
      out.push(`<button type="${escapeAttr(type || "submit")}"${common}>${escapeHtml(label || "Button")}</button>`);
    }
  }

  function emitElement(el, root, out) {
    const isHiddenInput = el.tagName && el.tagName.toLowerCase() === "input" &&
      ((el.getAttribute("type") || el.type || "") + "").toLowerCase() === "hidden";
    if ((!isHiddenInput && elementHardSkippable(el)) ||
        (el !== root && !isHiddenInput && !visibleElement(el)) ||
        elementLooksLikeChrome(el, root)) return;

    const tag = el.tagName.toLowerCase();
    if (tag === "a") return emitAnchor(el, out);
    if (tag === "img") return emitImage(el, out);
    if (tag === "br") {
      out.push("<br>");
      return;
    }
    if (tag === "input" || tag === "textarea" || tag === "select" || tag === "button")
      return emitControl(el, out);

    let outTag = "";
    let attrs = "";
    if (/^h[1-6]$/.test(tag)) outTag = tag;
    else if (tag === "p" || tag === "li" || tag === "ul" || tag === "ol" ||
             tag === "pre" || tag === "blockquote") outTag = tag;
    else if (tag === "form") {
      const forms = Array.from(document.forms || []);
      const formIndex = forms.indexOf(el);
      outTag = "form";
      attrs =
        ` action="${escapeAttr(absoluteUrl(el.getAttribute("action") || window.location.href) || window.location.href)}"` +
        ` method="${escapeAttr((el.getAttribute("method") || "get").toLowerCase())}"` +
        ` data-simplebrowse-form-index="${formIndex >= 0 ? formIndex : 0}"`;
    } else {
      const display = window.getComputedStyle(el).display;
      if (display === "block" || display === "list-item" || display === "table" ||
          display === "flex" || display === "grid" || tag === "main" ||
          tag === "article" || tag === "section" || tag === "div")
        outTag = "div";
    }

    if (outTag) out.push(`<${outTag}${attrs}>`);
    for (const child of Array.from(el.childNodes || [])) emitNode(child, root, out);
    if (el.shadowRoot) {
      for (const child of Array.from(el.shadowRoot.childNodes || [])) emitNode(child, root, out);
    }
    if (outTag) out.push(`</${outTag}>`);
  }

  function emitNode(node, root, out) {
    if (node.nodeType === Node.TEXT_NODE) emitTextNode(node, out);
    else if (node.nodeType === Node.ELEMENT_NODE) emitElement(node, root, out);
  }

  function emitRenderedSnapshot(root, out) {
    const seenLines = new Set();
    const text = root ?
      (typeof root.innerText === "string" ? root.innerText : (root.textContent || "")) :
      "";
    let emitted = 0;

    for (const rawLine of text.split(/\n+/)) {
      const line = cleanText(rawLine);
      if (!line) continue;
      if (line.length < 3 && !/[0-9A-Za-z]/.test(line)) continue;
      const key = line.toLowerCase();
      if (seenLines.has(key)) continue;
      seenLines.add(key);
      out.push(`<p>${escapeHtml(line)}</p>`);
      emitted++;
      if (emitted >= 800) break;
    }

    const seenLinks = new Set();
    const links = [];
    for (const a of Array.from((root || document).querySelectorAll("a[href]"))) {
      if (!visibleElement(a)) continue;
      const url = absoluteUrl(a.getAttribute("href") || "");
      const label = elementLabel(a);
      if (!url || !label) continue;
      const key = `${label}\n${url}`;
      if (seenLinks.has(key)) continue;
      seenLinks.add(key);
      links.push({label, url});
      if (links.length >= 300) break;
    }
    if (links.length) {
      out.push("<h2>Links</h2><ul>");
      for (const link of links) {
        out.push(`<li><a href="${escapeAttr(link.url)}">${escapeHtml(link.label)}</a></li>`);
      }
      out.push("</ul>");
    }

    const controls = Array.from((root || document).querySelectorAll("input, textarea, select, button"));
    const emittedControls = new Set();

    for (const form of Array.from((root || document).querySelectorAll("form"))) {
      if (!visibleElement(form)) continue;
      emitElement(form, root, out);
      for (const c of Array.from(form.querySelectorAll("input, textarea, select, button")))
        emittedControls.add(c);
    }

    for (const control of controls) {
      if (emittedControls.has(control)) continue;
      if (!visibleElement(control)) continue;
      const type = ((control.getAttribute("type") || control.type || "") + "").toLowerCase();
      if (type === "hidden") continue;
      out.push("<form>");
      emitControl(control, out);
      out.push("</form>");
    }

    return emitted + links.length + controls.length;
  }

  /*
 * Browser mode: preserve the complete visible page interface.
 *
 * The old bestContentRoot() call was readability extraction.  It threw away
 * navigation, download panels, disclosure controls, forms, and other pieces
 * of web applications.  WebKit snapshots now walk the visible document body.
 * The fast/static loader remains SimpleBrowse's reader-oriented path.
 */
const root = document.body || document.documentElement;
  const snapshot = [];
  snapshot.push("<!doctype html>\n<html><head><title>");
  snapshot.push(escapeHtml(document.title || ""));
  snapshot.push("</title></head><body><main data-simplebrowse-snapshot=\"visible\">");
  const beforeStructured = snapshot.length;
  emitElement(root, root, snapshot);
  if (snapshot.length === beforeStructured)
    emitRenderedSnapshot(root, snapshot);
  snapshot.push("</main></body></html>");

  return JSON.stringify({
    url: window.location.href,
    title: document.title || "",
    html: snapshot.join("")
  });
})()
"""

FORM_SUBMIT_SCRIPT = r"""
(() => {
  const payload = JSON.parse(%s);
  window.__simplebrowse_submit_debug = []; 
  const dbg = (msg) => window.__simplebrowse_submit_debug.push(String(msg)); 
  dbg("url before: " + window.location.href);
  dbg("payload: " + JSON.stringify(payload));
  function formScore(form) {
    if (!form) return -1;
    const elements = Array.from(form.elements || []);
    let score = 0;

    for (const control of payload.controls || []) {
      if (!control.name) continue;
      for (const el of elements) {
        if (el.name !== control.name) continue;
        score += control.active ? 20 : 5;
        const type = ((el.getAttribute("type") || el.type || "") + "").toLowerCase();
        if ((type === "search" || control.name === "q") && control.value) score += 30;
      }
    }

    if (form.querySelector("input[type='search'], input[name='q']")) score += 25;
    if ((form.getAttribute("role") || "").toLowerCase() === "search") score += 10;
    return score;
  }

  const forms = Array.from(document.forms || []);
  let form = forms[payload.form_index] || null;
  let best = form;
  let bestScore = formScore(form);

  for (const candidate of forms) {
    const score = formScore(candidate);
    if (score > bestScore) {
      best = candidate;
      bestScore = score;
    }
  }

  form = best || forms[0];
  dbg("forms: " + forms.length);
  dbg("chosen form index: " + forms.indexOf(form));
  dbg("chosen form action: " + (form ? form.action : ""));
  dbg("chosen form method: " + (form ? form.method : ""));
  dbg("chosen elements: " + (form ? Array.from(form.elements || []).map(e => (e.tagName||"") + ":" + (e.name||"") + ":" + (e.type||"")).join("|") : ""));
  if (!form) return "no form";

  function fire(el, type, extra) {
    let event;
    if (type === "keydown" || type === "keyup") {
      event = new KeyboardEvent(type, Object.assign({
        bubbles: true,
        cancelable: true,
        key: "Enter",
        code: "Enter",
        keyCode: 13,
        which: 13
      }, extra || {}));
    } else {
      event = new Event(type, {bubbles: true, cancelable: true});
    }
    el.dispatchEvent(event);
  }

  function matchingElements(control) {
    const elements = Array.from(form.elements || []);
    if (control.name) {
      const named = elements.filter((el) => el.name === control.name);
      if (named.length) return named;
    }
    return [];
  }

  let active = null;
  for (const control of payload.controls || []) {
    const elements = matchingElements(control);
    for (const el of elements) {
      const tag = (el.tagName || "").toLowerCase();
      const type = ((el.getAttribute("type") || el.type || "") + "").toLowerCase();
      if (type === "radio") {
        el.checked = !!control.checked && (!control.value || el.value === control.value);
      } else if (type === "checkbox") {
        el.checked = !!control.checked;
      } else if (tag === "select") {
        el.value = control.value || "";
        if (typeof control.selected === "number") el.selectedIndex = control.selected;
      } else if (type !== "submit" && type !== "button") {
        el.value = control.value || "";
      }
      fire(el, "keydown");
      fire(el, "input");
      fire(el, "change");
      fire(el, "keyup");
      if (control.active) active = el;
    }
  }

  if ((form.method || "get").toLowerCase() === "get") {
    const params = new URLSearchParams();

    // Reader snapshots intentionally omit non-visible fields, but hidden
    // inputs often carry routing information (for example, Wikimedia's
    // `family=wiktionary`). Preserve those native form values.
    for (const el of Array.from(form.elements || [])) {
      const type = ((el.getAttribute("type") || el.type || "") + "").toLowerCase();
      if (type === "hidden" && el.name && !el.disabled)
        params.append(el.name, el.value || "");
    }

    for (const control of payload.controls || []) {
      if (!control.name) continue;
      if (control.active || control.value) {
        params.set(control.name, control.value || "");
      }
    }

    let target = new URL(form.action || window.location.href, window.location.href);

    if (target.hostname.endsWith("duckduckgo.com") && params.get("q")) {
      target = new URL("https://html.duckduckgo.com/html/");
    }

    target.search = params.toString();

    dbg("forced GET target: " + target.toString());
    return "SIMPLEBROWSE_NAVIGATE " + target.toString();
  }

  let submitter = null;
  if (payload.submit_name) {
    submitter = Array.from(form.elements || []).find((el) => {
      const type = ((el.getAttribute("type") || el.type || "") + "").toLowerCase();
      const tag = (el.tagName || "").toLowerCase();
      return el.name === payload.submit_name &&
        (!payload.submit_value || el.value === payload.submit_value) &&
        type === "submit";
    });
  }
  if (!submitter) {
    submitter = Array.from(form.elements || []).find((el) => {
      const type = ((el.getAttribute("type") || el.type || "") + "").toLowerCase();
      const tag = (el.tagName || "").toLowerCase();
      return type === "submit";
    });
  }

  if (active) {
    active.focus();
    fire(active, "keydown");
    fire(active, "keyup");
  }
  dbg("submitter chosen: " + (submitter ? ((submitter.name || "") + ":" + (submitter.type || "")) : "none"));

  if (form.requestSubmit) {
    form.requestSubmit(submitter || undefined);
    return "requestSubmit " + window.__simplebrowse_submit_debug.join("\\n");
  }

  const event = new Event("submit", {bubbles: true, cancelable: true});
  if (form.dispatchEvent(event)) form.submit();

  return "submitted " + window.__simplebrowse_submit_debug.join("\\n");
})()
"""


def fail(message, code=1):
    print(f"simplebrowse-webkitd: {message}", file=sys.stderr)
    return code


def load_gi():
    try:
        import gi

        gi.require_version("Gtk", "3.0")
        gi.require_version("WebKit2", "4.1")
        from gi.repository import GLib, Gtk, WebKit2

        return GLib, Gtk, WebKit2
    except Exception as exc:
        raise RuntimeError(
            "missing WebKitGTK Python bindings "
            "(need python3-gi and WebKit2GTK 4.1 introspection)"
        ) from exc


def read_payload(stdin, size):
    data = stdin.read(size)
    if len(data) != size:
        raise EOFError("truncated command payload")
    trail = stdin.read(1)
    if trail != b"\n":
        raise ValueError("malformed command payload")
    return data.decode("utf-8", "replace")


def emit_response(status, url="", title="", html="", error="", code=0):
    url_b = (url or "").encode("utf-8", "replace")
    title_b = (title or "").encode("utf-8", "replace")
    error_b = (error or "").encode("utf-8", "replace")
    html_b = (html or "").encode("utf-8", "replace")
    out = sys.stdout.buffer
    out.write(f"{HEADER}\n".encode("ascii"))
    out.write(f"STATUS {status}\n".encode("ascii"))
    out.write(f"CODE {code}\n".encode("ascii"))
    out.write(f"URL_LENGTH {len(url_b)}\n".encode("ascii"))
    out.write(f"TITLE_LENGTH {len(title_b)}\n".encode("ascii"))
    out.write(f"ERROR_LENGTH {len(error_b)}\n".encode("ascii"))
    out.write(f"HTML_LENGTH {len(html_b)}\n\n".encode("ascii"))
    out.write(url_b)
    out.write(title_b)
    out.write(error_b)
    out.write(html_b)
    out.flush()


def set_if_available(obj, name, value):
    setter = getattr(obj, name, None)
    if not setter:
        return
    try:
        setter(value)
    except Exception as exc:
        print(f"simplebrowse-webkitd: {name} unavailable: {exc}", file=sys.stderr)


class BrowserDaemon:
    def __init__(self, GLib, Gtk, WebKit2, settle_ms, timeout_ms,
                 resnapshot_ms, max_resnapshots):
        self.GLib = GLib
        self.Gtk = Gtk
        self.WebKit2 = WebKit2
        self.settle_ms = max(settle_ms, 0)
        self.timeout_ms = max(timeout_ms, 1000)
        self.resnapshot_ms = max(resnapshot_ms, 50)
        self.max_resnapshots = max(max_resnapshots, 0)
        self.command_id = 0
        self.state = None
        self.loop = None

        context = self._create_context()
        self.view = WebKit2.WebView.new_with_context(context)
        settings = self.view.get_settings()
        self._configure_settings(settings)
        user_agent = os.environ.get("SIMPLEBROWSE_WEBKIT_UA")
        if user_agent and hasattr(settings, "set_user_agent"):
            settings.set_user_agent(user_agent)

        self.window = Gtk.OffscreenWindow()
        self.window.set_default_size(1280, 900)
        self.window.add(self.view)
        self.window.show_all()

        self.view.connect("load-changed", self.on_load_changed)
        self.view.connect("load-failed", self.on_load_failed)

    def _configure_settings(self, settings):
        set_if_available(settings, "set_enable_javascript", True)
        set_if_available(settings, "set_enable_plugins", False)
        set_if_available(settings, "set_auto_load_images", False)
        set_if_available(settings, "set_load_icons_ignoring_image_load_setting", False)
        set_if_available(settings, "set_enable_media", False)
        set_if_available(settings, "set_enable_mediasource", False)
        set_if_available(settings, "set_enable_media_stream", False)
        set_if_available(settings, "set_enable_encrypted_media", False)
        set_if_available(settings, "set_enable_webgl", False)
        set_if_available(settings, "set_enable_2d_canvas_acceleration", False)
        set_if_available(settings, "set_enable_accelerated_2d_canvas", False)
        set_if_available(settings, "set_enable_dns_prefetching", False)
        set_if_available(settings, "set_enable_offline_web_application_cache", False)
        set_if_available(settings, "set_enable_write_console_messages_to_stdout", False)
        set_if_available(settings, "set_javascript_can_open_windows_automatically", False)
        set_if_available(settings, "set_media_playback_requires_user_gesture", True)

    def _state_dir(self):
        data_home = os.environ.get("XDG_DATA_HOME") or os.path.join(
            os.path.expanduser("~"), ".local", "share"
        )
        return os.environ.get(
            "SIMPLEBROWSE_WEBKIT_STATE_DIR",
            os.path.join(data_home, "simplebrowse", "webkit"),
        )

    def _create_context(self):
        state_dir = self._state_dir()
        cache_dir = os.path.join(state_dir, "cache")
        os.makedirs(state_dir, exist_ok=True)
        os.makedirs(cache_dir, exist_ok=True)
        try:
            manager = self.WebKit2.WebsiteDataManager(
                base_data_directory=state_dir,
                base_cache_directory=cache_dir,
            )
            context = self.WebKit2.WebContext.new_with_website_data_manager(manager)
        except Exception as exc:
            print(f"simplebrowse-webkitd: persistent data manager unavailable: {exc}",
                  file=sys.stderr)
            context = self.WebKit2.WebContext.get_default()
        self._configure_context(context, state_dir)
        return context

    def _configure_context(self, context, state_dir):
        os.makedirs(state_dir, exist_ok=True)
        cookie_path = os.path.join(state_dir, "cookies.sqlite")
        try:
            manager = context.get_cookie_manager()
            manager.set_persistent_storage(
                cookie_path, self.WebKit2.CookiePersistentStorage.SQLITE
            )
        except Exception as exc:
            print(f"simplebrowse-webkitd: cookie persistence unavailable: {exc}", file=sys.stderr)

    def command_matches(self, command_id):
        return (
            self.state is not None and
            self.state.get("id") == command_id and
            not self.state.get("done")
        )

    def finish(self, command_id, status, url="", title="", html="", error="", code=0):
        if not self.command_matches(command_id):
            return False
        if status == "OK":
            try:
                self.view.stop_loading()
            except Exception:
                pass
        self.state.update({
            "done": True,
            "response": {
                "status": status,
                "url": url or self.view.get_uri() or self.state.get("url", ""),
                "title": title or self.view.get_title() or "",
                "html": html or "",
                "error": error or "",
                "code": code,
            },
        })
        if self.loop:
            self.loop.quit()
        return False

    def evaluate_now(self, command_id):
        if not self.command_matches(command_id):
            return False
        if self.state.get("eval_started"):
            return False
        self.state["eval_started"] = True
        self.view.run_javascript(DOM_EXTRACT_SCRIPT, None, self.js_finished, command_id)
        return False

    def js_finished(self, webview, result, command_id):
        if not self.command_matches(command_id):
            return False
        try:
            js_result = webview.run_javascript_finish(result)
            value = js_result.get_js_value()
            data = json.loads(value.to_string())
            url = data.get("url") or webview.get_uri() or self.state.get("url", "")
            title = data.get("title") or webview.get_title() or ""
            html = data.get("html") or ""
            if not html.strip():
                return self.finish(command_id, "ERROR", url=url, title=title,
                                   error="post-JavaScript DOM was empty", code=0)
            if self.snapshot_is_too_thin(html, title):
                retries = int(self.state.get("extract_retries") or 0)
                if retries < self.max_resnapshots:
                    self.state["extract_retries"] = retries + 1
                    self.state["eval_started"] = False
                    self.GLib.timeout_add(self.resnapshot_ms, self.evaluate_now,
                                          command_id)
                    return False
            return self.finish(command_id, "OK", url=url, title=title, html=html,
                               code=self.current_status_code())
        except Exception as exc:
            return self.finish(command_id, "ERROR", error=f"DOM extraction failed: {exc}", code=0)

    def snapshot_is_too_thin(self, html, title):
        if "data-simplebrowse-snapshot" not in html:
            return False
        plain = re.sub(r"<[^>]+>", " ", html or "")
        lower_plain = plain.lower()
        meaningful = sum(1 for ch in plain if ch.isalnum())
        title_chars = sum(1 for ch in (title or "") if ch.isalnum())
        links = html.lower().count("<a ")
        if links != 0:
            return False
        if meaningful <= max(16, title_chars + 8):
            return True
        return (
            meaningful <= max(80, title_chars + 40) and
            re.search(r"\b(loading|please wait|just a moment)\b", lower_plain)
        )

    def schedule_evaluate(self, command_id):
        self.GLib.timeout_add(self.settle_ms, self.evaluate_now, command_id)

    def current_status_code(self):
        try:
            resource = self.view.get_main_resource()
            response = resource.get_response() if resource else None
            code = int(response.get_status_code()) if response else 0
            return code if code > 0 else 200
        except Exception:
            return 200

    def submit_now(self, command_id):
        if not self.command_matches(command_id):
            return False
        if self.state.get("submit_started"):
            return False
        self.state["submit_started"] = True
        script = FORM_SUBMIT_SCRIPT % json.dumps(self.state.get("payload") or "{}")
        self.view.run_javascript(script, None, self.submit_finished, command_id)
        return False

    def submit_finished(self, webview, result, command_id):
        if not self.command_matches(command_id):
            return False
        try:
            js_result = webview.run_javascript_finish(result)
            try:
                value = js_result.get_js_value()
                text = str(value.to_string())
                with open("/tmp/simplebrowse-submit.log", "a", encoding="utf-8") as fp:
                    fp.write("\n--- submit result ---\n")
                    fp.write(text + "\n")
                    fp.write("uri after: " + str(webview.get_uri()) + "\n")
                if text.startswith("SIMPLEBROWSE_NAVIGATE "):
                    target = text[len("SIMPLEBROWSE_NAVIGATE "):].strip()
                    webview.load_uri(target)
                    self.state["submit_started"] = True
                    return False
            except Exception as log_exc:
                with open("/tmp/simplebrowse-submit.log", "a", encoding="utf-8") as fp:
                    fp.write("\n--- submit log failed ---\n")
                    fp.write(str(log_exc) + "\n")
        except Exception as exc:
            print(f"simplebrowse-webkitd: form submit failed: {exc}", file=sys.stderr)
        self.schedule_evaluate(command_id)
        return False

    def on_load_changed(self, _webview, event):
        if self.state is None or self.state.get("done"):
            return
        command_id = self.state["id"]
        if event == self.WebKit2.LoadEvent.COMMITTED:
            if self.state["kind"] == "load" or self.state.get("submit_started"):
                self.schedule_evaluate(command_id)
        if event == self.WebKit2.LoadEvent.FINISHED:
            if self.state["kind"] == "load":
                self.schedule_evaluate(command_id)
            elif self.state["kind"] == "submit":
                if not self.state.get("submit_started"):
                    self.GLib.timeout_add(self.settle_ms, self.submit_now, command_id)
                else:
                    self.schedule_evaluate(command_id)

    def on_load_failed(self, _webview, _event, uri, error):
        if self.state is None or self.state.get("done"):
            return False
        return self.finish(
            self.state["id"], "ERROR", url=uri or self.state.get("url", ""),
            error=f"load failed: {error.message}", code=0,
        )

    def on_timeout(self, command_id):
        if not self.command_matches(command_id):
            return False
        if not self.state.get("eval_started"):
            self.evaluate_now(command_id)
            return False
        return self.finish(command_id, "ERROR", error="timed out waiting for WebKit page", code=0)

    def begin_command(self, kind, url, payload=None):
        self.command_id += 1
        command_id = self.command_id
        self.state = {
            "id": command_id,
            "kind": kind,
            "url": url,
            "payload": payload,
            "done": False,
            "eval_started": False,
            "submit_started": False,
            "extract_retries": 0,
            "response": None,
        }
        self.loop = self.GLib.MainLoop()
        self.GLib.timeout_add(self.timeout_ms, self.on_timeout, command_id)
        return command_id

    def load(self, url):
        self.begin_command("load", url)
        self.view.load_uri(url)
        self.loop.run()
        return self.state["response"]

    def submit(self, url, payload):
        command_id = self.begin_command("submit", url, payload)
        current = self.view.get_uri() or ""
        if current == url:
            self.GLib.idle_add(self.submit_now, command_id)
        else:
            self.view.load_uri(url)
        self.loop.run()
        return self.state["response"]

    def close(self):
        self.window.destroy()


def serve(stdin, daemon):
    while True:
        line = stdin.readline()
        if not line:
            break
        line = line.decode("ascii", "replace").strip()
        if not line:
            continue
        if line == "QUIT":
            break

        try:
            parts = line.split()
            if len(parts) == 2 and parts[0] == "LOAD":
                url = read_payload(stdin, int(parts[1]))
                response = daemon.load(url)
            elif len(parts) == 3 and parts[0] == "SUBMIT":
                url = read_payload(stdin, int(parts[1]))
                payload = read_payload(stdin, int(parts[2]))
                response = daemon.submit(url, payload)
            else:
                emit_response("ERROR", error=f"unknown command: {line}", code=2)
                continue
            emit_response(**response)
        except Exception as exc:
            emit_response("ERROR", error=str(exc), code=1)


def main(argv):
    parser = argparse.ArgumentParser(description="Persistent WebKitGTK backend for SimpleBrowse")
    parser.add_argument("--version", action="version", version=f"simplebrowse-webkitd {VERSION}")
    parser.add_argument("--settle-ms", type=int,
                        default=int(os.environ.get("SIMPLEBROWSE_JS_SETTLE_MS", str(DEFAULT_SETTLE_MS))))
    parser.add_argument("--timeout-ms", type=int,
                        default=int(os.environ.get("SIMPLEBROWSE_JS_TIMEOUT_MS", "20000")))
    parser.add_argument("--resnapshot-ms", type=int,
                        default=int(os.environ.get("SIMPLEBROWSE_JS_RESNAPSHOT_MS", str(DEFAULT_RESNAPSHOT_MS))))
    parser.add_argument("--max-resnapshots", type=int,
                        default=int(os.environ.get("SIMPLEBROWSE_JS_MAX_RESNAPSHOTS", str(DEFAULT_MAX_RESNAPSHOTS))))
    args = parser.parse_args(argv)

    try:
        GLib, Gtk, WebKit2 = load_gi()
    except RuntimeError as exc:
        return fail(str(exc), 127)

    ok, _ = Gtk.init_check([])
    if not ok:
        return fail("GTK could not open a display; WebKit backend needs a graphical session", 2)

    daemon = BrowserDaemon(GLib, Gtk, WebKit2, args.settle_ms, args.timeout_ms,
                           args.resnapshot_ms, args.max_resnapshots)
    try:
        serve(sys.stdin.buffer, daemon)
    finally:
        daemon.close()
    return 0


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
