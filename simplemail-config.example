# SimpleMail configuration
#
# SimpleMail uses mbsync to synchronize your email into ~/Mail.
#
# Configure mbsync for your email provider, then point it at this Mail
# directory:
#
#     https://isync.sourceforge.io/
#
# Outgoing mail is sent using msmtp. Configure ~/.msmtprc separately.

maildir=~/Mail

inbox=Inbox
sent=Sent
drafts=Drafts
archive=Archive
trash=Trash

send=msmtp
