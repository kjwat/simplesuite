# SimpleMail configuration
#
# SimpleMail uses mbsync to synchronize your email into a local Maildir.
#
# Configure mbsync for your email provider, then point it at this Mail
# directory:
#
#     https://isync.sourceforge.io/
#
# Outgoing mail is sent using msmtp. Configure ~/.msmtprc separately.

# Maildir precedence:
# 1. uncommented maildir below
# 2. SIMPLEMAIL_MAILDIR
# 3. existing ~/.local/share/simplemail/mail when ~/Mail is absent
# 4. ~/Mail
#
# maildir=~/Mail

inbox=Inbox
sent=Sent
drafts=Drafts
archive=Archive
trash=Trash

sync_cmd=mbsync inbox
send_cmd=msmtp -t
# from=Your Name <you@example.com>
